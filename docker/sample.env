# M8Flow Docker Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=spiffworkflow
MYSQL_USER=spiffuser
MYSQL_PASSWORD=spiffpass
MYSQL_PORT=3306

# Application Ports
BACKEND_PORT=8000
FRONTEND_PORT=7001

# M8Flow Feature Flags
M8FLOW_ENABLE_MULTI_TENANCY=true
M8FLOW_ENABLE_INTEGRATIONS=true

# Backend Configuration
SPIFFWORKFLOW_BACKEND_PERMISSIONS_FILE_NAME=
SPIFFWORKFLOW_BACKEND_OPEN_ID_SERVER_URL=

# Development Mode
NODE_ENV=development
FLASK_ENV=development

