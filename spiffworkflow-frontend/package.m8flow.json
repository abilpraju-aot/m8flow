{
  "name": "m8flow-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "M8Flow Frontend - AOT Technologies workflow platform based on SpiffArena",
  "scripts": {
    "build": "vite build --config vite.config.m8flow.ts",
    "build:upstream": "vite build",
    "eslint": "./node_modules/.bin/eslint src --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write --list-different src/**/*.[tj]s{,x} ../extensions/frontend/**/*.[tj]s{,x}",
    "lint": "./node_modules/.bin/eslint src ../extensions/frontend --ext .js,.jsx,.ts,.tsx && npm run typecheck",
    "lint:fix": "./node_modules/.bin/eslint --fix src ../extensions/frontend --ext .js,.jsx,.ts,.tsx",
    "serve": "vite preview --config vite.config.m8flow.ts",
    "start": "vite --config vite.config.m8flow.ts",
    "start:upstream": "vite",
    "startopen": "vite --host 0.0.0.0 --config vite.config.m8flow.ts",
    "test": "vitest run --coverage",
    "test:extensions": "vitest run --coverage ../extensions/frontend",
    "typecheck": "./node_modules/.bin/tsc --noEmit --project tsconfig.m8flow.json"
  }
}

