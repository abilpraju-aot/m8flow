{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,

    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["vite/client", "node"],

    "module": "esnext",
    "target": "ESNext",
    "moduleResolution": "Node",

    "isolatedModules": true,

    "baseUrl": ".",
    "paths": {
      "@m8flow/*": ["src/*"],
      "@spiff/*": ["../../spiffworkflow-frontend/src/*"]
    }
  },
  "include": ["src", "../../spiffworkflow-frontend/src"]
}
